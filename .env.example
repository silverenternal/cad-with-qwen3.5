# Ollama API Key 配置文件
#
# 获取 API Key:
# 1. 访问 https://ollama.com/connect
# 2. 登录你的账户
# 3. 复制显示的 API Key
#
# ⚠️ 安全警告:
# - 请勿将此文件提交到版本控制系统
# - 请勿将 API Key 分享给他人
# - 如怀疑泄露，请立即在 Ollama 官网重新生成
#
# 使用方法：复制此文件为 .env 并填入真实 API Key

# ==================== 核心配置 ====================

# Ollama Cloud API Key (必需)
OLLAMA_API_KEY=your_api_key_here

# 可选：本地 Ollama 服务地址 (默认：http://localhost:11434)
# OLLAMA_LOCAL_URL=http://localhost:11434

# 可选：Web 服务运行端口 (默认：3000)
# SERVER_PORT=3000

# ==================== 数据库配置 ====================

# 可选：数据库连接 URL (默认：SQLite ./data/telemetry.db)
# 支持 SQLite: sqlite://./cad_ocr.db
# 支持 PostgreSQL: postgres://user:pass@localhost:5432/dbname
# DATABASE_URL=sqlite://./cad_ocr.db

# ==================== 灰度发布配置 ====================

# 可选：启用灰度发布 (默认：false)
# 设置为 true 启用白名单和配额限制
GRAY_RELEASE_ENABLED=true

# 可选：灰度白名单用户列表 (逗号分隔)
# 只有在白名单中的用户可以访问服务
GRAY_RELEASE_WHITELIST=user_abc123,user_def456,user_test789

# 可选：每用户每日配额限制 (默认：100)
# 超出配额后用户将无法继续请求，直到次日重置
GRAY_RELEASE_QUOTA_PER_USER=50

# ==================== 日志与监控 ====================

# 可选：日志级别 (trace/debug/info/warn/error)
# RUST_LOG=info

# 可选：运行环境 (development/staging/production)
# APP_ENV=development

